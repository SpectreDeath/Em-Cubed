{
  "name": "LLM Integration Test Workflow",
  "description": "Test workflow demonstrating LLM surface integration with other surfaces",
  "steps": [
    {
      "id": "step1",
      "skill_id": "NLP/test-rag-pipeline",
      "input_mapping": {
        "query": "input.query",
        "knowledge_base": "input.knowledge_base",
        "top_k": "input.top_k"
      },
      "output_mapping": {
        "generated_response": "workflow.rag_response",
        "retrieved_docs": "workflow.docs"
      }
    },
    {
      "id": "step2",
      "skill_id": "DECISION_MAKING/test-decision-maker",
      "input_mapping": {
        "context": "workflow.rag_response",
        "options": "input.options",
        "criteria": "input.criteria"
      },
      "output_mapping": {
        "selected_option": "output.decision",
        "reasoning": "output.reasoning",
        "confidence": "output.confidence"
      }
    }
  ]
}