{
  "name": "LLM Advanced Features Demo Workflow",
  "description": "Demonstrates streaming, function calling, and advanced LLM capabilities",
  "steps": [
    {
      "id": "step1",
      "skill_id": "LLM_PROCESSING/advanced-llm-processor",
      "input_mapping": {
        "prompt": "input.prompt",
        "use_streaming": "input.use_streaming",
        "temperature": "input.temperature"
      },
      "output_mapping": {
        "response": "workflow.llm_response",
        "features_used": "workflow.features_used"
      }
    },
    {
      "id": "step2",
      "skill_id": "NLP/natural-language-generator",
      "input_mapping": {
        "prompt": "workflow.llm_response",
        "context": "workflow.features_used"
      },
      "output_mapping": {
        "generated_text": "output.final_output",
        "generation_metadata": "output.metadata"
      }
    }
  ]
}