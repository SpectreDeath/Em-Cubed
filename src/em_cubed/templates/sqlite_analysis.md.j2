def preprocess(input_data):
    """Validate and prepare data for SQL analysis."""
    # Ensure required fields
    if "table" not in input_data:
        raise ValueError("Input must contain 'table' key")
    return input_data

def postprocess(sql_result):
    """Format SQL results into final output."""
    return {"aggregated": sql_result, "status": "ok"}
```

